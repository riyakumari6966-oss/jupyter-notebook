    "#move all negative numbers to the end of the array \n",
    "num=[-1,-4,3,7,-5,1,-9]\n",
    "left=0\n",
    "for right in range(len(num)):\n",
    "    if num[right]>=0:\n",
    "        positive=[x for x in num if x>=0]   \n",
    "        negative=[x for x in num if x<0]\n",
    "        num=positive+negative\n",
    "\n",
    "print(num)\n",
    "        "
   ]
