   "source": [
    "#Two Sum II\n",
    "nums=[2,7,11,13]\n",
    "target=9\n",
    "left=0\n",
    "right=len(nums)-1\n",
    "while left<right:\n",
    "    current_sum=nums[left]+nums[right]\n",
    "    if current_sum==target:\n",
    "        print([left+1,right+1])\n",
    "        break\n",
    "    elif current_sum>target:\n",
    "        right-=1\n",
    "    else:\n",
    "        left+=1"
   ]
  }
