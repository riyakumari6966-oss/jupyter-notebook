   "source": [
    "#array containing 0,1,2 element sort without using sorting algo\n",
    "arr=[1,0,2]\n",
    "for i in range(len(arr)):\n",
    "    for j in range(0,len(arr)-i-1):\n",
    "        if arr[j]>arr[j+1]:\n",
    "            arr[j],arr[j+1]=arr[j+1],arr[j]\n",
    "\n",
    "print(arr)"
   ]
  }
 ],
