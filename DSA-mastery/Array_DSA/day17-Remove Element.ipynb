    "#removing element\n",
    "nums=[0,1,2,2,3,0,4,2]\n",
    "val=2\n",
    "left=0\n",
    "for right in range(len(nums)):\n",
    "    if nums[right]!=val:\n",
    "        nums[left],nums[right]=nums[right],nums[left]\n",
    "        left+=1\n",
    "print(len(nums[:left]))\n",
    "print(nums[:left])"
   ]
