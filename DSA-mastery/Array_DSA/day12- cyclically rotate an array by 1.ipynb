   "source": [
    "#cyclically rotate an array by one\n",
    "num=[1,2,3,4,5]\n",
    "temp=num[-1]\n",
    "for i in range(len(num)-1,0,-1):\n",
    "    num[i]=num[i-1]\n",
    "num[0]=temp\n",
    "print(num)"
   ]
  }
 ],
