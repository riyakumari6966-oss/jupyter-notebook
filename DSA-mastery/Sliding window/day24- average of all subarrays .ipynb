   "source": [
    "def average_subarray(nums,k):\n",
    "    current_avg=sum(nums[:k])/k\n",
    "    max_avg=current_avg\n",
    "    for i in range(k,len(nums)):\n",
    "        current_avg+=(nums[i]-nums[i-k])/k\n",
    "        max_avg=max(current_avg,max_avg)\n",
    "    return max_avg\n",
    "nums=[1,2,3,2,3,4]\n",
    "k=3\n",
    "average_subarray(nums,k)\n"
   ]
  }
 ],
