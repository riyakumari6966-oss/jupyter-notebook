   "source": [
    "def isSubsequence(s: str, t: str) -> bool:\n",
    "    p1=p2=0\n",
    "    while p1<len(s) and p2<len(t):\n",
    "        if s[p1]==t[p2]:\n",
    "            p1+=1\n",
    "        p2+=1\n",
    "\n",
    "    return p1==len(s)\n",
    "\n",
    "s=\"rsh\"\n",
    "t=\"reshika\"\n",
    "print(isSubsequence(s,t))\n"
   ]
  }
 ],
