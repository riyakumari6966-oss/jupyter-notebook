   "source": [
    "#reverse a string\n",
    "str=\"Reshika\"\n",
    "str1=list(str)\n",
    "print(str)\n",
    "print(str1)\n",
    "left=0\n",
    "right=len(str1)-1\n",
    "while left<right:\n",
    "    str1[left],str1[right]=str1[right],str1[left]\n",
    "    left+=1\n",
    "    right-=1\n",
    "print(str1)\n",
    "print(\"\".join(str1))"
   ]
  }
